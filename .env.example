# Copy to .env for local development. Never commit a real .env file.

ENVIRONMENT=local
APP_NAME=awa-backend
LOG_LEVEL=INFO
LOG_JSON=false

# API
API_V1_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=["http://localhost:5173"]

# Database
DATABASE_URL=mssql+aioodbc://mssql:mssql@localhost:1433/awa?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=awa-auction-workers
KAFKA_TOPIC_BIDS=auction.bids
KAFKA_TOPIC_BID_RESULTS=auction.bid_results

# Auth (JWT verification against Azure B2C / UAE Pass OIDC issuer)
AUTH_ISSUER=https://example-tenant.b2clogin.com/tid/v2.0/
AUTH_AUDIENCE=api://awa-backend
AUTH_JWKS_URL=https://example-tenant.b2clogin.com/tid/discovery/v2.0/keys
AUTH_JWT_ALGORITHMS=["RS256"]

# Auth (local email/password: sign up / sign in / forgot password)
# Generate a strong secret, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
# REQUIRED in production - the app refuses to start with the dev placeholder.
AUTH_JWT_SECRET=dev-insecure-change-me
AUTH_LOCAL_ISSUER=awa-backend
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_PASSWORD_RESET_TTL_SECONDS=3600
AUTH_EMAIL_VERIFICATION_TTL_SECONDS=86400
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCKOUT_SECONDS=900
FRONTEND_BASE_URL=http://localhost:5173

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=awa-backend
PROMETHEUS_METRICS_PATH=/metrics
